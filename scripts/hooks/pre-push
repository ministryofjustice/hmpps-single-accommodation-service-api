#!/bin/bash
set -e

echo "Running git pre-push hooks"
echo "Running 'gradle ktlintCheck detekt'"

./gradlew ktlintCheck detekt

echo "ktlintCheck complete."

# Run prek hooks
# Resolve PREK
if [ -n "$PREK" ] && [ -x "$PREK" ]; then
    :
elif command -v prek >/dev/null 2>&1; then
    PREK="$(command -v prek)"
elif [ -x "/opt/homebrew/bin/prek" ]; then
    PREK="/opt/homebrew/bin/prek"
else
    echo "Error: could not find executable 'prek'. Set PREK or ensure 'prek' is in PATH." >&2
    exit 1
fi

# Determine the directory containing this script for use as the hook directory.
HERE="$(cd -- "$(dirname -- "${BASH_SOURCE[0]:-$0}")" && pwd)"

"$PREK" hook-impl --hook-dir "$HERE" --script-version 4 --hook-type=pre-push -- "$@"
